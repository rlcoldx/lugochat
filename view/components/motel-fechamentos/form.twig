<div class="border-bottom px-3 py-3 mb-2">
    <h4 class="mb-0">{{ item ? 'EDITAR FECHAMENTO' : 'NOVA DATA DE FECHAMENTO' }}</h4>
</div>
<div class="px-3 py-2 pt-0">
    <form action="javascript:void(0);" method="POST" id="salvar_fechamento">
        <input type="hidden" name="json_response" value="1">
        {% if item %}
        <input type="hidden" name="id_grupo" value="{{ item.id_grupo }}">
        <input type="hidden" id="fechamento_moteis_selecionados" value="{{ item.id_moteis|join(',') }}">
        {% endif %}

        <div class="mb-3">
            <label class="form-label" for="fechamento_data">Data de fechamento</label>
            <input type="date" id="fechamento_data" name="date_fechamento" class="form-control" required value="{{ item ? item.date_fechamento : '' }}">
        </div>

        <div class="mb-3">
            <label class="form-label" for="fechamento_proprietario">Proprietário</label>
            <select id="fechamento_proprietario" name="proprietario" class="form-control" required>
                <option value="">Selecione o proprietário</option>
                {% for p in proprietarios %}
                <option value="{{ p }}" {{ item and item.proprietario == p ? 'selected' : '' }}>{{ p }}</option>
                {% endfor %}
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Motéis (clique para desmarcar)</label>
            <div id="fechamento_moteis_tags" class="d-flex flex-wrap gap-1 p-3 border rounded" style="min-height: 52px;">
                <span class="small text-secondary" id="fechamento_moteis_placeholder">Selecione um proprietário para listar os motéis.</span>
            </div>
        </div>

        <div class="d-flex justify-content-start gap-2 pt-2 border-top">
            <button type="submit" class="btn btn-primary" id="fechamento_btn_salvar">Salvar</button>
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
        </div>
    </form>
</div>

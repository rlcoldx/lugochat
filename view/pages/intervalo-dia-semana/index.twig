{% extends "layout/layoutMaster.twig" %}

{% block title %}Intervalos{% endblock %}

{% block body %}

<div class="content-body">
    <div class="container-fluid">
        <div class="page-titles">
            <div class="d-flex flex-wrap align-items-center justify-content-between">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ DOMAIN }}">Home</a></li>
                    <li class="breadcrumb-item active"><a href="javascript:void(0)">Intervalos</a></li>
                </ol>
            </div>
        </div>

        {% if _get.ok is defined %}
        <div class="alert alert-success">Registro salvo com sucesso.</div>
        {% endif %}
        {% if _get.erro is defined %}
            {% if _get.erro == 'validacao' %}
            <div class="alert alert-warning">Preencha dia da semana e horários.</div>
            {% else %}
            <div class="alert alert-danger">Não foi possível concluir a operação.</div>
            {% endif %}
        {% endif %}

        <div class="d-flex justify-content-between align-items-center">
            <h3 class="content-title card-title mb-0 text-white">Intervalos por dia da semana</h3>
            <a href="javascript:void(0)" data-bs-toggle="modal-remote" data-remote="{{ DOMAIN }}/intervalos-dia-semana/add" data-bs-target="#intervalosemanamodal" class="btn btn-primary btn-sm"><i class="fa-solid fa-plus"></i> Novo intervalo</a>
        </div>

        <p class="mb-3 text-white">Cadastre períodos recorrentes na semana <strong class="text-primary">(ex.: de Segunda 08:00 até Terça 16:00)</strong>. Neste período seu estabelecimento estará <strong class="text-primary">fechado</strong>.</p>

        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover mb-0" id="datatable_intervalo_dia_semana">
                        <thead>
                            <tr>
                                <th>Período</th>
                                <th>Nome / observação</th>
                                <th class="text-end" width="120">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for r in regras %}
                            <tr>
                                <td>{{ r.periodo_txt }}</td>
                                <td class="text-uppercase">{% if r.nome %}{{ r.nome }}{% else %}—{% endif %}</td>
                                <td class="text-end">
                                    <a href="javascript:void(0)" data-bs-toggle="modal-remote" data-remote="{{ DOMAIN }}/intervalos-dia-semana/edit/{{ r.id }}" data-bs-target="#intervalosemanamodal" class="btn btn-sm py-1 btn-primary me-1" title="Editar"><i class="fa fa-pencil"></i></a>
                                    <button type="button" class="btn btn-sm py-1 btn-danger btn-excluir-intervalo-dia-semana" data-regra-id="{{ r.id }}" title="Excluir"><i class="fa fa-trash"></i></button>
                                </td>
                            </tr>
                            {% else %}
                            <tr>
                                <td colspan="3">Nenhum intervalo cadastrado.</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="intervalosemanamodal" tabindex="-1" role="dialog" aria-labelledby="intervalosemanamodalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-body"></div>
        </div>
    </div>
</div>

<script src="{{ DOMAIN }}/view/assets/vendor/datatables/js/jquery.dataTables.min.js"></script>
<script src="{{ DOMAIN }}/view/assets/js/pages/intervalo-dia-semana-motel.js"></script>
<script>
(function ($) {
    'use strict';
    if ($('#datatable_intervalo_dia_semana tbody tr').length && $('#datatable_intervalo_dia_semana tbody td[colspan]').length === 0) {
        $('#datatable_intervalo_dia_semana').DataTable({
            order: [[0, 'asc']],
            pageLength: 25,
            language: { url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/pt-BR.json' }
        });
    }
})(jQuery);
</script>

{% endblock %}

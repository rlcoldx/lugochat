{% extends "layout/layoutMaster.twig" %}

{% block title %}Integração API{% endblock %}

{% block body %}

<div class="content-body">
    <div class="container-fluid">
    
	    <div class="d-flex justify-content-between align-items-center mb-4">
	        <div>
	            <h3 class="content-title card-title mb-0">Tokens de Integração API</h3>
	            <p class="mb-0">Gerencie os tokens de acesso à API para cada motel</p>
	        </div>
	        <div>
	            <a href="javascript:void(0)" data-bs-toggle="modal-remote" data-remote="{{ DOMAIN }}/api/integracao/add" data-bs-target="#tokenmodal" class="btn btn-primary btn-sm"><i class="fa-solid fa-plus"></i> Add Novo Token</a>
	        </div>
	    </div>
    
        <div class="card">
            <div class="card-body">
                <div class="table-responsive" data-api-tokens-refresh="{{ DOMAIN }}/api/integracao/tokens-refresh">
                    <table id="datatable" class="table dataTable">
                        <thead>
                            <tr role="row">
                                <th>Motel</th>
                                <th>Status</th>
                                <th>Sistema</th>
                                <th>Token</th>
                                <th>Acessos</th>
                                <th>Criado em</th>
                                <th width="150">Ação</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for token in tokens %}
                            <tr class="token-{{ token.id }}" data-token-id="{{ token.id }}">
                                <td class="align-middle fw-bold text-uppercase">{{ token.nome_motel|upper }}</td>
                                <td class="align-middle api-col-status">
                                    {% if token.api_online %}
                                        <span class="badge bg-success">Online</span>
                                    {% else %}
                                        <span class="badge bg-danger">Offline</span>
                                    {% endif %}
                                </td>
                                <td class="align-middle fw-bold">{{ token.sistema }}</td>
                                <td class="align-middle">
                                    <div class="d-flex align-items-center">
                                        <code class="token-value">{{ token.token }}</code>
                                        <button class="btn btn-sm btn-link py-1 copy-token" data-token="{{ token.token }}" title="Copiar Token">
                                            <i class="fa fa-copy"></i>
                                        </button>
                                    </div>
                                </td>
                                <td class="align-middle api-col-acessos"><span class="fs-5 fw-bold">{{ token.acessos }}</span></td>
                                <td class="align-middle">{{ token.date_create|date("d/m/Y H:i") }}</td>
                                <td class="align-middle">
                                    <div class="d-flex justify-content-end align-items-center">
                                        <a href="javascript:void(0)" data-bs-toggle="modal-remote" data-remote="{{ DOMAIN }}/api/integracao/edit/{{ token.id }}" data-bs-target="#tokenmodal" class="btn btn-sm btn-primary py-1 me-1" title="Editar">
                                            <i class="fa fa-pencil"></i>
                                        </a>
                                        <a href="javascript:void(0)" class="btn btn-sm btn-danger py-1 deletar-token" data-id="{{ token.id }}" title="Deletar">
                                            <i class="fa fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>

<div class="modal fade" id="tokenmodal" tabindex="-1" role="dialog" aria-labelledby="tokenmodalLabel">
    <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-body"></div>
        </div>
    </div>
</div>

<script>
window.BDM_API_INTEGRACAO_REFRESH_URL = {{ (DOMAIN ~ '/api/integracao/tokens-refresh')|json_encode|raw }};
</script>
<script src="{{ DOMAIN }}/view/assets/vendor/datatables/js/jquery.dataTables.min.js"></script>
<script src="{{ DOMAIN }}/view/assets/vendor/datatables/js/datatables.init.js"></script>
<script src="{{ DOMAIN }}/view/assets/js/pages/api-integracao.js"></script>
{# Polling roda aqui (sync), fora do $(document).ready) do arquivo principal — garante GET no Network #}
<script>
(function ($) {
    'use strict';

    function resolveRefreshUrl() {
        var u = (typeof window.BDM_API_INTEGRACAO_REFRESH_URL === 'string')
            ? window.BDM_API_INTEGRACAO_REFRESH_URL.trim()
            : '';
        if (u) {
            return u;
        }
        var wrap = document.querySelector('.table-responsive[data-api-tokens-refresh]');
        if (wrap) {
            var v = (wrap.getAttribute('data-api-tokens-refresh') || '').trim();
            if (v) {
                return v;
            }
        }
        var path = window.location.pathname.replace(/\/list\/?$/i, '/tokens-refresh');
        if (path !== window.location.pathname) {
            return window.location.origin + path;
        }
        return '';
    }

    function applyTokensPayload(data) {
        if (!data || !data.tokens || !data.tokens.length) {
            return;
        }

        function patchRow($tr, t) {
            if (!$tr || !$tr.length) {
                return;
            }
            var acessos = (typeof t.acessos !== 'undefined' && t.acessos !== null) ? Number(t.acessos) : 0;
            var badge = t.online
                ? '<span class="badge bg-success">Online</span>'
                : '<span class="badge bg-danger">Offline</span>';
            $tr.find('td.api-col-status').first().html(badge);
            $tr.find('td.api-col-acessos').first().html('<span class="fs-5 fw-bold">' + acessos + '</span>');
        }

        var map = {};
        data.tokens.forEach(function (t) {
            map[String(t.id)] = t;
        });

        if (typeof $.fn.DataTable !== 'undefined' && $.fn.DataTable.isDataTable('#datatable')) {
            $('#datatable').DataTable().rows().every(function () {
                var $tr = $(this.node());
                var id = $tr.attr('data-token-id');
                if (id && map[id]) {
                    patchRow($tr, map[id]);
                }
            });
            return;
        }

        $('#datatable tbody tr[data-token-id]').each(function () {
            var $tr = $(this);
            var id = $tr.attr('data-token-id');
            if (id && map[id]) {
                patchRow($tr, map[id]);
            }
        });
    }

    function refreshTokensRow() {
        var url = resolveRefreshUrl();
        if (!url || !document.getElementById('datatable')) {
            return;
        }
        var sep = url.indexOf('?') >= 0 ? '&' : '?';
        $.ajax({
            url: url + sep + '_=' + Date.now(),
            type: 'GET',
            dataType: 'json',
            cache: false,
            success: applyTokensPayload
        });
    }

    if (typeof $ === 'undefined' || typeof $.ajax !== 'function') {
        return;
    }

    refreshTokensRow();
    setInterval(refreshTokensRow, 10000);
})(jQuery);
</script>

{% endblock %}


{% extends "layout/layoutMaster.twig" %}

{% block title %}{{ titulo }}{% endblock %}

{% block body %}

<div class="content-body">
    
    <!-- row -->
    <div class="container-fluid">
        <div class="page-titles">
            <div class="d-flex flex-wrap align-items-center justify-content-between">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ DOMAIN }}">Home</a></li>
                    <li class="breadcrumb-item active"><a href="javascript:void(0)">{{ titulo }}</a></li>
                </ol>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <form method="get" action="{{ DOMAIN }}/clientes" class="row g-2 align-items-end mb-4">
                    <div class="col-md-6 col-lg-4">
                        <label class="form-label">Buscar cliente</label>
                        <input type="text" name="search" class="form-control" placeholder="Nome, e-mail, CPF ou telefone" value="{{ filters.search }}">
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn btn-primary"><i class="fa fa-search me-1"></i> Buscar</button>
                    </div>
                    {% if filters.search %}
                    <div class="col-auto">
                        <a href="{{ DOMAIN }}/clientes" class="btn btn-outline-secondary">Limpar</a>
                    </div>
                    {% endif %}
                    <div class="col-12">
                        <small>{{ total }} cliente(s) encontrado(s).</small>
                    </div>
                </form>

                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr role="row">
                                <th width="50"></th>
                                <th>Nome</th>
                                <th>Email</th>
                                <th>CPF</th>
                                <th>Telefone</th>
                                <th>Status</th>
                                <th class="text-end">Data</th>
                                <th class="text-end">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for cliente in clientes %}
                            <tr class="cliente-{{ cliente.id }}">
                                <td width="50">#{{ offset + loop.index }}</td>
                                <td>{{ cliente.nome }}</td>
                                <td>{{ cliente.email }}</td>
                                <td>{{ cliente.cpf }}</td>
                                <td>{{ cliente.telefone }}</td>
                                <td class="status-cliente-{{ cliente.id }}">
                                    {% if cliente.banido > 0 %}
                                        <span class="badge bg-danger">Banido</span>
                                    {% else %}
                                        <span class="badge bg-success">Ativo</span>
                                    {% endif %}
                                </td>
                                <td class="text-end text-nowrap">{{ cliente.data|date("d-m-Y \\a\\s H:i", "America/Sao_Paulo") }}</td>
                                <td class="text-end acoes-cliente-{{ cliente.id }}">
                                    {% if cliente.banido > 0 %}
                                        <button type="button"
                                                class="btn btn-success btn-sm"
                                                onclick="desbanirCliente({{ cliente.id }}, '{{ cliente.nome|e('js') }}')"
                                                data-bs-toggle="tooltip"
                                                data-bs-title="Remover banimento">
                                            <i class="fa fa-unlock"></i> Desbanir
                                        </button>
                                    {% else %}
                                        <button type="button"
                                                class="btn btn-danger btn-sm"
                                                onclick="banirCliente({{ cliente.id }}, '{{ cliente.nome|e('js') }}')"
                                                data-bs-toggle="tooltip"
                                                data-bs-title="Banir cliente">
                                            <i class="fa fa-ban"></i> Banir
                                        </button>
                                    {% endif %}
                                </td>
                            </tr>
                            {% endfor %}
                            {% if clientes|length == 0 %}
                            <tr>
                                <td colspan="8" class="text-center py-4">Nenhum cliente encontrado.</td>
                            </tr>
                            {% endif %}
                        </tbody>
                    </table>
                </div>

                {% if pagination %}
                <nav aria-label="Paginação" class="mt-4">
                    <ul class="pagination pagination-circle justify-content-center">
                        {% if pagination.before %}
                            {% for p in pagination.before %}
                            <li class="page-item"><a class="page-link" href="?page={{ p.number }}{% if filters.search %}&search={{ filters.search }}{% endif %}">{{ p.number }}</a></li>
                            {% endfor %}
                        {% endif %}
                        {% if pagination.beforeMiddle %}
                            {% for p in pagination.beforeMiddle %}
                            <li class="page-item"><a class="page-link" href="?page={{ p.number }}{% if filters.search %}&search={{ filters.search }}{% endif %}">{{ p.number }}</a></li>
                            {% endfor %}
                        {% endif %}
                        {% if pagination.actual %}
                        <li class="page-item active"><a class="page-link" href="#">{{ pagination.actual }}</a></li>
                        {% endif %}
                        {% if pagination.lateMiddle %}
                            {% for p in pagination.lateMiddle %}
                            <li class="page-item"><a class="page-link" href="?page={{ p.number }}{% if filters.search %}&search={{ filters.search }}{% endif %}">{{ p.number }}</a></li>
                            {% endfor %}
                        {% endif %}
                        {% if pagination.late %}
                            {% for p in pagination.late %}
                            <li class="page-item"><a class="page-link" href="?page={{ p.number }}{% if filters.search %}&search={{ filters.search }}{% endif %}">{{ p.number }}</a></li>
                            {% endfor %}
                        {% endif %}
                    </ul>
                </nav>
                {% endif %}
            </div>
        </div>

    </div>
</div>

<script>
function atualizarLinhaCliente(id, banido) {
    var status = document.querySelector('.status-cliente-' + id);
    var acoes = document.querySelector('.acoes-cliente-' + id);

    if (banido) {
        if (status) status.innerHTML = '<span class="badge bg-danger">Banido</span>';
        if (acoes) acoes.innerHTML = '<button type="button" class="btn btn-success shadow btn-xs sharp" onclick="desbanirCliente(' + id + ', \'\')" title="Remover banimento"><i class="fa fa-unlock"></i></button>';
    } else {
        if (status) status.innerHTML = '<span class="badge bg-success">Ativo</span>';
        if (acoes) acoes.innerHTML = '<button type="button" class="btn btn-danger shadow btn-xs sharp" onclick="banirCliente(' + id + ', \'\')" title="Banir cliente"><i class="fa fa-ban"></i></button>';
    }
}

function enviarAcaoCliente(url, id) {
    return fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'id=' + encodeURIComponent(id)
    }).then(function (r) { return r.json(); });
}

function banirCliente(id, nome) {
    Swal.fire({
        icon: 'warning',
        title: 'Banir cliente?',
        html: 'O cliente <strong>' + (nome || '') + '</strong> não poderá mais fazer login, criar novas contas ou reservas — do mesmo celular, CPF, e-mail ou IP.',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        confirmButtonText: 'Sim, banir',
        cancelButtonText: 'Cancelar'
    }).then(function (res) {
        if (!res.isConfirmed) return;
        enviarAcaoCliente('{{ DOMAIN }}/clientes/banir', id).then(function (data) {
            if (data.success) {
                atualizarLinhaCliente(id, true);
                Swal.fire({ icon: 'success', title: 'Banido!', text: data.message, timer: 2000, showConfirmButton: false });
            } else {
                Swal.fire({ icon: 'error', title: 'Erro!', text: data.message });
            }
        }).catch(function () {
            Swal.fire({ icon: 'error', title: 'Erro!', text: 'Ocorreu um erro ao banir o cliente.' });
        });
    });
}

function desbanirCliente(id, nome) {
    Swal.fire({
        icon: 'question',
        title: 'Remover banimento?',
        html: 'O cliente <strong>' + (nome || '') + '</strong> voltará a poder usar o aplicativo normalmente.',
        showCancelButton: true,
        confirmButtonText: 'Sim, remover',
        cancelButtonText: 'Cancelar'
    }).then(function (res) {
        if (!res.isConfirmed) return;
        enviarAcaoCliente('{{ DOMAIN }}/clientes/desbanir', id).then(function (data) {
            if (data.success) {
                atualizarLinhaCliente(id, false);
                Swal.fire({ icon: 'success', title: 'Pronto!', text: data.message, timer: 2000, showConfirmButton: false });
            } else {
                Swal.fire({ icon: 'error', title: 'Erro!', text: data.message });
            }
        }).catch(function () {
            Swal.fire({ icon: 'error', title: 'Erro!', text: 'Ocorreu um erro ao remover o banimento.' });
        });
    });
}
</script>

{% endblock %}